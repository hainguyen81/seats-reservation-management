datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

model User {
  id            String        @id @default(uuid())
  username      String        @unique
  password      String        // hashed
  refreshToken  String?
  Bookings      Booking[]
}

model Seat {
  id         String        @id
  number     String        @unique
  status     String        // AVAILABLE, PENDING, BOOKED
  version    Int           @default(0) // for Optimistic Locking
  Booking    Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  seatId    String
  status    String   // PENDING, COMPLETED, FAILED
  createdAt DateTime @default(now())
  expiresAt DateTime // expired reservation if not paying
  user      User     @relation(fields: [userId], references: [id])
  seat      Seat     @relation(fields: [seatId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  // null or unauthorized webhook
  action      String   // HOLD, RELEASE, RELEASE_EXPIRED, PAYMENT_SUCCESS, PAYMENT_FAIL
  target      String   // seat id (Ex: "Seats: seat-1, seat-2")
  status      String   // SUCCESS, FAILED
  details     String?  // error detail or payload
  ipAddress   String?  // referal request IP
  ipAddresses String?  // referal request IP if many IPs via proxies
  createdAt   DateTime @default(now())
}
