# -------------------------------------------------
# DB
# -------------------------------------------------
# SQLite
DATABASE_URL="file:./dev.db"

# PostgreSQL
#DATABASE_URL="postgresql://postgres:password123@postgres-db:6432/seat_reservation?schema=public&pgbouncer=true"
#DIRECT_DATABASE_URL="postgresql://postgres:password123@localhost:5432/seat_reservation?schema=public"

# -------------------------------------------------
# REDIS
# -------------------------------------------------
# REDIS_URL=redis://localhost:6379
REDIS_TTL=3
REDIS_RETIES_PER_REQUEST=1
REDIS_CONN_TIMEOUT=2000 # in seconds

# -------------------------------------------------
# Authentication
# + change both value AUTH_PROVIDER to "firebase"/"custom" to use the separated authentication
# -------------------------------------------------
# Firebase Admin
AUTH_PROVIDER="custom" # or "custom"
FIREBASE_PROJECT_ID = "<!--firebase project identity-->"
FIREBASE_CLIENT_EMAIL = "<!--firebase client email-->"
FIREBASE_PRIVATE_KEY = "<!--firebase private key-->"

# -------------------------------------------------
# Firebase Client
# -------------------------------------------------
# Client-Side Firebase API Key Security Disclosure
# - The client-side `apiKey` utilized within the Firebase Client configuration differs fundamentally
# from conventional API keys, which are typically used to restrict backend resources.
# Instead, it functions purely as a public **Project Identifier** that enables the frontend application
# to route requests to the designated Google infrastructure.
# 
# Data confidentiality and operational integrity (including read/write loops and state mutations within the seat reservation matrix)
# are strictly enforced via standard defensive layers:
# - Server-Side Session Verification: Authenticated through `firebase-admin` via secure, HTTP-Only session cookies.
# - Database Integrity: Protected by server-managed ACID transactions that eliminate concurrent race conditions.
# 
# Consequently, exposing the `apiKey` within the client-side bundle complies with Google’s architectural specifications
# and introduces zero vulnerability to the core security posture of the platform.
NEXT_PUBLIC_AUTH_PROVIDER="custom" # or "custom"
NEXT_PUBLIC_FIREBASE_API_KEY="MOCK_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="://firebaseapp.com"
NEXT_PUBLIC_FIREBASE_DB_URL="://db.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJET="MOCK-PROJECT"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="://appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGE_SENDER="000000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:0000000000000000000000"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-0000000000"

# -------------------------------------------------
# MIDDLEWARE
# -------------------------------------------------
# in RAM cache
RAM_RATE_LIMITER=false # true for using
RAM_RATE_LIMIT_REQUESTS=5
RAM_RATE_LIMIT_TIMEOUT_PER_REQUEST=10 # in seconds
# in Upstash Redis
UPSTASH_RATE_LIMITER=false # true for using
UPSTASH_RATE_LIMIT_URL=
UPSTASH_RATE_LIMIT_TOKEN=
UPSTASH_RATE_LIMIT_REQUESTS=5
UPSTASH_RATE_LIMIT_TIMEOUT_PER_REQUEST=10 # in seconds

# JWT Secret Token (Should be changed in PROD)
JWT_SECRET="seats-reservation-secret-key-2026"
ACCESS_TOKEN_EXPIRY=15 # in minutes
REFRESH_TOKEN_EXPIRY=1 # in days
RESERVE_EXPIRY=15 # in minutes

# Only for testing, 0 to ignore test data seeding
TOTAL_SEATS=12
